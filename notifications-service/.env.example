# Optional. Comma-separated list of Kafka bootstrap brokers to connect to.
KAFKA_BROKERS=localhost:9092

# Optional. Topic the consumer subscribes to.
KAFKA_TOPIC=notifications

# Optional. Consumer group ID — instances sharing this ID split partitions between them.
KAFKA_GROUP_ID=notifications-service

# Optional. PostgreSQL connection string.
DATABASE_URL=postgres://postgres:postgres@localhost:5433/notifications

# Optional. Skip low-risk alerts with probability below this threshold (0..1).
FAILURE_THRESHOLD=0.8

# Optional. `stub` logs instead of sending; `smtp` sends real emails.
EMAIL_PROVIDER=stub

# Required only when EMAIL_PROVIDER=smtp.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
EMAIL_USER=fathimasafrina57@gmail.com
EMAIL_PASS=indg dija amtb vokn

# Used by `make test` to point integration tests at the test Postgres
# spun up by docker-compose.test.yml. Tests are skipped when unset.
# TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5434/notifications_test?sslmode=disable