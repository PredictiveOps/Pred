# Database Configuration
# PostgreSQL connection string for the predictions database
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://predictions_user:predictions_password@localhost:5433/predictions

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=True

# Model Configuration
MODEL_DIR=./artifacts/models
MODEL_NAME=vibration_isolation_forest
MODEL_VERSION=v1

# Kafka Configuration
KAFKA_BROKERS=localhost:9092
KAFKA_PREDICTIONS_TOPIC=predictions
KAFKA_ALERTS_TOPIC=alerts
KAFKA_CONSUMER_GROUP=alert-notifier
KAFKA_ENABLED=true

# Prediction Persister Configuration (separate consumer group)
# KAFKA_CONSUMER_GROUP=prediction-persister

# Logging
LOG_LEVEL=INFO
