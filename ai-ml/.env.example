# Database Configuration
# PostgreSQL connection string for the predictions database
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://predictions_user:predictions_password@localhost:5433/predictions

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=True

# Model Configuration
MODEL_DIR=./results/models
MODEL_NAME=vibration_isolation_forest
MODEL_VERSION=v1

# Kafka
KAFKA_BROKERS=localhost:9092
ML_FEATURES_TOPIC=ml-features
ML_KAFKA_GROUP_ID=ml-service
ML_KAFKA_OFFSET_RESET=latest
NOTIFICATIONS_TOPIC=notifications
# "email" or "push"
NOTIFICATION_TYPE=email

# Logging
LOG_LEVEL=INFO
